# نسخ هذا الملف إلى .env وعدل القيم

# قاعدة البيانات (من Render PostgreSQL Dashboard)
DATABASE_URL=postgresql://username:password@host:5432/database_name

# مفتاح JWT (اكتب أي نص عشوائي طويل 32+ حرف)
JWT_SECRET=your-super-secret-key-here-minimum-32-characters-long!!

# البورت (Render بيحدده تلقائياً، مش لازم تعدله)
PORT=8000
